{
  "extends": "@ultra-pdf/typescript-config/tsconfig.next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ui/components": ["../../packages/ui/src/components"],
      "@ui/components/*": ["../../packages/ui/src/components/*"],
      "@ui/components/ui/*": ["../../packages/ui/src/components/ui/*"],
      "@ui/lib": ["../../packages/ui/src/lib"],
      "@ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@ui/hooks": ["../../packages/ui/src/hooks"],
      "@ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@ui/lib/utils": ["../../packages/ui/src/lib/utils.ts"],
      "@ui/assets/*": ["../../packages/ui/src/assets/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx"
  ],
  "exclude": ["node_modules"],
  "references": [
    {
      "path": "../../packages/pdf_builder"
    },
    {
      "path": "../../packages/typescript_config"
    },
    {
      "path": "../../packages/ui"
    }
  ]
}
