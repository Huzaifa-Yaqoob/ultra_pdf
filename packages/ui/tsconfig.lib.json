{
  "extends": "@ultra-pdf/typescript-config/tsconfig.lib.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "types": ["node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@ui/components": ["./src/components"],
      "@ui/components/*": ["./src/components/*"],
      "@ui/components/ui/*": ["./src/components/ui/*"],
      "@ui/lib": ["./src/lib"],
      "@ui/lib/*": ["./src/lib/*"],
      "@ui/hooks": ["./src/hooks"],
      "@ui/hooks/*": ["./src/hooks/*"],
      "@ui/lib/utils": ["./src/lib/utils.ts"],
      "@ui/assets/*": ["./src/assets/fonts/*"]
    },
    "lib": ["esnext", "dom", "dom.iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../typescript_config/tsconfig.lib.json"
    }
  ]
}
